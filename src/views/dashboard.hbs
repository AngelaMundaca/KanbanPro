<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Dashboard de Tareas</title>

    <!-- CSS -->
    <link rel="stylesheet" href="/public/css/styles.css">
</head>

<body>

    <h1>Dashboard de Tareas</h1>

    <!-- FORMULARIO -->
    <form method="POST" action="/api/tareas">
        <input type="text" name="titulo" placeholder="Nombre de la tarea" required>
        <button type="submit">Agregar</button>
    </form>

    <hr>

    <!-- LISTADO DE TAREAS -->
    <div class="contenedor-tareas">

        {{#each tareas}}
        <div class="tarea">
            <h3>{{this.titulo}}</h3>
            <p><strong>Estado:</strong> {{this.estado}}</p>
        </div>
        {{/each}}

        {{!-- Si no hay tareas --}}
        {{#unless tareas.length}}
        <p>No hay tareas disponibles</p>
        {{/unless}}

    </div>

</body>

</html>